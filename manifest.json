{
  "manifest_version": 3,
  "name": "Kajabi Video Downloader",
  "version": "0.1.0",
  "description": "Download Wistia-hosted videos from Kajabi course pages.",
  "permissions": ["downloads", "activeTab", "storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.kajabi.com/*",
    "*://*.mykajabi.com/*",
    "*://*.wistia.com/*",
    "*://*.wistia.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.kajabi.com/*", "*://*.mykajabi.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
